{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lexian",
  "version": "0.1.0",
  "identifier": "com.vyleene.lexian",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:lexian.db"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "Lexian - Simple Student Information System",
        "width": 1200,
        "height": 905,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
